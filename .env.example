# WeatherAPI Configuration
# Copy this file to .env and fill in your actual values.

# Required: API key from https://www.weatherapi.com/my/
TAP_WEATHERAPI_API_KEY=your_api_key_here

# Required: JSON array of locations (zip codes, city names, lat/lon pairs, etc.)
TAP_WEATHERAPI_LOCATIONS=["10001","90210"]

# Required: Earliest date for historical data sync (YYYY-MM-DD)
# TAP_WEATHERAPI_START_DATE=2026-01-01

# Optional: Number of forecast days to retrieve (1–14, default 5)
# TAP_WEATHERAPI_FORECAST_DAYS=5

# Optional: Enable bulk requests (requires Pro+, Business, or Enterprise plan)
# TAP_WEATHERAPI_USE_BULK_REQUESTS=false

# Optional: Max locations per bulk POST request (5–50, default 50)
# TAP_WEATHERAPI_BULK_REQUEST_CHUNK_SIZE=50
